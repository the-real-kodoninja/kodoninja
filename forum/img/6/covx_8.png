/* submit tip */
.sbm_TIP {
    top: 0;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: #3d4347;
    z-index: 1000;
    position: fixed;
    display: none;
}

.sbm_TIP-Inr {
    margin: 50px auto;
    height: 650px;
    width: 700px;
    color: #fff;
    overflow-y: scroll;
    overflow-x: hidden;
}

.sbm_TIP-Inr h3 {
    text-align: center;
}

.sbm_TIP-Inr .fa-close {
    margin: -38px 0px 0px;
}

.sbm_TIP-Inr label {
    color: #fff;
}

.sbm_TIP-Inr input[type="text"], .sbm_TIP-Inr input[type="tel"], .sbm_TIP-Inr input[type="email"] .sbm_TIP-Inr input, textarea, [contenteditable] {
    font: inherit;
    line-height: 1.5;
    padding: 20px 12px;
    overflow: auto;
    width: auto;
}

.sbm_TIP-Inr input[type="text"], .sbm_TIP-Inr input[type="tel"], .sbm_TIP-Inr input[type="email"] {
    margin: 0px 5px 0px 0px;
}

.sbm_TIP-Inr input[type="text"], .sbm_TIP-Inr input[type="tel"], .sbm_TIP-Inr input[type="email"], .sbm_TIP-Inr table {
    width: 100%;
}

.sbm_TIP-Inr [contenteditable] {
    background: #fff;
    color: #333;
    height: 300px;
} 

.sbm_TIP-Inr button {
    width: 100%;
    background-color: rgba(155, 46, 46, 0.8);
    padding: 20px;
    border: none;
    border-radius: 6px;
    color: #fff;
} 

[contenteditable=true]:empty:before {
    content: attr(placeholder);
    pointer-events: none;
    display: block; /* firefox */
}

.sbm_TIP_BdyTxtInr:focus {
    border-color: #871e1f;
    outline: 2px solid #871e1f;
    box-shadow: 0px 1px 2px rgba(0, 0, 0, 0.075) inset, 0px 0px 5px rgba(135,30,31, 0.5);
    transition: all 0.3s linear;
}

.sbm_TIP-Inr input[type="file"] {
  opacity: 0; /* Make it invisible */
  width: 0; /* Remove any extra space it occupies */
  height: 0;
}

.sbm_TIP-Inr label#sbm_lbl_1 {
  display: inline-block;
  padding: 5px 25px 15px 0px;
  background-color: rgba(213, 199, 157, 0.9);
  color: #333;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border: none;
  border-radius: 5px;
  cursor: pointer;
width: 100%;
}

.sbm_TIP-Inr label#sbm_lbl_1:hover {
  background-color: rgba(155, 46, 46, 0.8);
  border: none;
  color: #fff;
}

.sbm_TIP-Inr progress {
    width: 100%;
    display: none;
}

