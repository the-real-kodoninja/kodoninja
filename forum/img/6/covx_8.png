        var return_data = hr.responseText; 
        if(return_data != "") { 
            dbSr.style.display = "block"; 
            dbSr.innerHTML = return_data; 
        } 
    } 
    }
    hr.send("s="+s+"&k="+k+"&v="+v);
}; 
