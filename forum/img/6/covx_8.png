	var rx = new RegExp; 
	rx = /[^a-z0-9 #@]/gi; 
	var replaced = s.search(rx) >= 0; 
	if(replaced) { 
	     s = s.replace(rx, ""); 
        dbS.value = s; 
	} if(s == "") { 
        dbSr.style.display = "none"; 
        return false; 
	} 
	dbSr.style.display = "block"; 
	dbSr.innerHTML = 'checking for <b>'+s+'</b>';
	var hr = new XMLHttpRequest(); 
	hr.open("POST",`${m_path}icl/sch/dbS.php`, true); 
